# ============================================
# SENSITIVE FILES - NEVER COMMIT THESE!
# ============================================

# Environment variables and API keys
.env
.env.*
!.env.example
*.local

# Secret/API key files
secrets.properties
secrets.json
**/secrets/
api_keys.dart

# ============================================
# Flutter/Dart
# ============================================

# Dart tool
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/

# Build outputs
/build/
**/build/
*.class

# Generated files
*.g.dart
*.freezed.dart
*.mocks.dart
lib/generated_plugin_registrant.dart

# Coverage
/coverage/

# Documentation
**/doc/api/

# Symbolication & obfuscation
app.*.symbols
app.*.map.json

# ============================================
# Android
# ============================================

# Gradle
.gradle/
**/android/.gradle/
**/android/gradle/
**/android/gradlew
**/android/gradlew.bat

# Local configuration
**/android/local.properties
**/android/key.properties
**/android/*.keystore
**/android/*.jks

# Build artifacts
**/android/app/debug/
**/android/app/profile/
**/android/app/release/
**/android/app/outputs/
**/android/**/GeneratedPluginRegistrant.java

# Google Services (contains project-specific data)
**/google-services.json

